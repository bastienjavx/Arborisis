# =============================================================================
# Arborisis — Template d'environnement Docker
# =============================================================================
# Copiez ce fichier en .env et ajustez les valeurs.
# NE JAMAIS commiter le fichier .env final.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=Arborisis
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# Base de données (PostgreSQL + PostGIS)
# -----------------------------------------------------------------------------
DB_CONNECTION=pgsql
DB_HOST=db
DB_PORT=5432
DB_DATABASE=arborisis
DB_USERNAME=arborisis
DB_PASSWORD=change_me_in_production

# -----------------------------------------------------------------------------
# Sessions & Cache (Redis)
# -----------------------------------------------------------------------------
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=redis

# -----------------------------------------------------------------------------
# Queue (Redis)
# -----------------------------------------------------------------------------
QUEUE_CONNECTION=redis

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------------------------------------
# Broadcasting
# -----------------------------------------------------------------------------
BROADCAST_CONNECTION=reverb

# -----------------------------------------------------------------------------
# Filesystem
# -----------------------------------------------------------------------------
FILESYSTEM_DISK=local
AVATAR_DISK=
AUDIO_DISK=audio

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Cloudflare R2 (Object Storage)
# -----------------------------------------------------------------------------
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_DEFAULT_REGION=auto
R2_BUCKET=
R2_ENDPOINT=arborisis
R2_USE_PATH_STYLE_ENDPOINT=true
R2_URL=
R2_SIGNING_KEY=

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Vite
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Web Push (VAPID)
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@arborisis.com

# -----------------------------------------------------------------------------
# Discord
# -----------------------------------------------------------------------------
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URL=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BOT_HOST=127.0.0.1
DISCORD_BOT_PORT=3001
DISCORD_INTERNAL_API_TOKEN=
DISCORD_RADIO_VOICE_CHANNEL_ID=
DISCORD_RADIO_AUTO_JOIN=true

# -----------------------------------------------------------------------------
# Web Radio
# -----------------------------------------------------------------------------
RADIO_ENGINE=icecast
RADIO_INTERNAL_TOKEN=
RADIO_PUBLIC_STREAM_URL=
RADIO_ICY_METAINT=8192
RADIO_CHUNK_SIZE=8192
RADIO_CROSSFADE_SECONDS=4
RADIO_DJ_ENABLED=true
RADIO_DJ_ANNOUNCEMENT_FREQUENCY=3
RADIO_DJ_VOICE_PROVIDER=elevenlabs
RADIO_DJ_VOICE_ID=
ICECAST_BASE_URL=http://127.0.0.1:8000
ICECAST_MOUNT=/arborisis.mp3
ICECAST_ADMIN_USER=admin
ICECAST_ADMIN_PASSWORD=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_192
ELEVENLABS_STABILITY=0.55
ELEVENLABS_SIMILARITY_BOOST=0.75
ELEVENLABS_STYLE=0.20
ELEVENLABS_USE_SPEAKER_BOOST=true

# -----------------------------------------------------------------------------
# Audio Analysis Pipeline
# -----------------------------------------------------------------------------
ANALYZER_URL=
ANALYZER_SECRET=
ANALYZER_INTERNAL_API_TOKEN=
AUDIO_MAX_DURATION=600
AUDIO_MAX_FILE_SIZE_MB=500

# -----------------------------------------------------------------------------
# OpenRouter (Podcast IA)
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4.7
OPENROUTER_MAX_TOOL_STEPS=10
OPENROUTER_TIMEOUT=60

# -----------------------------------------------------------------------------
# Arborisis Agent
# -----------------------------------------------------------------------------
ARBORISIS_AGENT_WORKER_URL=
ARBORISIS_AGENT_TOKEN=
ARBORISIS_AGENT_TIMEOUT=45
ARBORISIS_AGENT_MEMORY_DISK=local
ARBORISIS_AGENT_MEMORY_PATH=agent-memory
ARBORISIS_AGENT_RATE_LIMIT_PER_MINUTE=6
ARBORISIS_AGENT_GUEST_RATE_LIMIT_PER_MINUTE=3
ARBORISIS_AGENT_DAILY_QUOTA=60
ARBORISIS_AGENT_GUEST_DAILY_QUOTA=15

# -----------------------------------------------------------------------------
# Nominatim (Geocoding)
# -----------------------------------------------------------------------------
NOMINATIM_ENABLED=true
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_TIMEOUT=8
NOMINATIM_USER_AGENT=Arborisis/1.0
NOMINATIM_INFER_SOUND_WALK_WAYPOINTS=true

# -----------------------------------------------------------------------------
# OSRM (Routing)
# -----------------------------------------------------------------------------
OSRM_ENABLED=true
OSRM_BASE_URL=https://routing.openstreetmap.de/routed-foot
OSRM_PROFILE=foot
OSRM_TIMEOUT=10
OSRM_USER_AGENT=Arborisis/1.0

# -----------------------------------------------------------------------------
# Blog IA
# -----------------------------------------------------------------------------
BLOG_AI_ENABLED=true
BLOG_AI_MODEL=anthropic/claude-opus-4.7
BLOG_DAILY_AT=07:00

# -----------------------------------------------------------------------------
# Radio Podcasts
# -----------------------------------------------------------------------------
RADIO_PODCAST_ENABLED=false
RADIO_PODCAST_INTERVAL_TRACKS=15
RADIO_PODCAST_MIN_DURATION=600
RADIO_PODCAST_MAX_DURATION=1200
RADIO_PODCAST_MIN_SOUNDS=4
RADIO_PODCAST_MAX_SOUNDS=7
RADIO_AUDIO_PRODUCTION_ENABLED=true
RADIO_AUDIO_PRODUCTION_AI_ENABLED=true
RADIO_AUDIO_PRODUCTION_AI_MODEL=anthropic/claude-opus-4.7
RADIO_AUDIO_PRODUCTION_MUSIC_ENABLED=true
RADIO_AUDIO_PRODUCTION_FX_ENABLED=true
RADIO_AUDIO_PRODUCTION_MAX_MUSIC_SECONDS=90
RADIO_AUDIO_PRODUCTION_MUSIC_VOLUME=0.12
RADIO_AUDIO_PRODUCTION_FIELD_BED_VOLUME=0.16
RADIO_AUDIO_PRODUCTION_IDENT_VOLUME=0.22
RADIO_AUDIO_PRODUCTION_IDENT_SECONDS=5

# -----------------------------------------------------------------------------
# Radio Host IA
# -----------------------------------------------------------------------------
RADIO_HOST_FLASH_ENABLED=false
RADIO_HOST_EMISSION_ENABLED=false
RADIO_HOST_VOICE_ID=
RADIO_HOST_AI_MODEL=anthropic/claude-opus-4.7
RADIO_HOST_STORAGE_DISK=r2

# -----------------------------------------------------------------------------
# Docker-specific
# -----------------------------------------------------------------------------
APP_PORT=80
DB_PORT=5432
REDIS_PORT=6379
