# syntax=docker/dockerfile:1.7

# =============================================================================
# Arborisis — Dockerfile Development
# PHP 8.4-FPM Alpine + Xdebug + Node.js pour hot-reload Vite
# =============================================================================

FROM php:8.4-fpm-alpine AS dev

WORKDIR /var/www/html

# Dépendances système + outils de développement
RUN apk add --no-cache \
    ca-certificates \
    curl \
    ffmpeg \
    freetype-dev \
    git \
    icu-dev \
    jpeg-dev \
    libpng-dev \
    libpq-dev \
    libzip-dev \
    unzip \
    libjpeg-turbo-dev \
    bash \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install -j"$(nproc)" \
        bcmath \
        gd \
        intl \
        opcache \
        pcntl \
        pdo_pgsql \
        sockets \
        zip \
    && pecl install redis xdebug \
    && docker-php-ext-enable redis xdebug

# Configuration Xdebug
RUN echo "xdebug.mode=develop,debug" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.start_with_request=yes" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.client_host=host.docker.internal" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.client_port=9003" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.idekey=arborisis" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini \
    && echo "xdebug.log_level=0" >> /usr/local/etc/php/conf.d/docker-php-ext-xdebug.ini

# Configuration PHP dev (sans opcache agressif)
COPY docker/php/php-dev.ini /usr/local/etc/php/conf.d/99-arborisis-dev.ini
COPY docker/php/uploads.ini /usr/local/etc/php/conf.d/uploads.ini

# Installer Composer
COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Créer l'utilisateur www-data
RUN set -eux; \
    addgroup -g 82 -S www-data 2>/dev/null || true; \
    adduser -u 82 -D -S -G www-data www-data 2>/dev/null || true

# Permissions
RUN mkdir -p \
    storage/app \
    storage/framework/cache \
    storage/framework/sessions \
    storage/framework/testing \
    storage/framework/views \
    storage/logs \
    bootstrap/cache \
    && chown -R www-data:www-data storage bootstrap/cache \
    && chmod -R 775 storage bootstrap/cache

# Entrypoint dev (migrations automatiques)
COPY docker/entrypoint-dev.sh /usr/local/bin/arborisis-entrypoint-dev
RUN chmod +x /usr/local/bin/arborisis-entrypoint-dev

ENTRYPOINT ["arborisis-entrypoint-dev"]
CMD ["php-fpm"]

EXPOSE 9000
