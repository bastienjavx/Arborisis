R2_SIGNING_KEY=

STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

VITE_APP_NAME="${APP_NAME}"

VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
