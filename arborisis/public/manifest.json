{
  "name": "Arborisis",
  "short_name": "Arborisis",
  "description": "L'archive sonore de la nature. Découvrez, partagez et préservez les sons du monde vivant.",
  "id": "/?source=pwa",
  "start_url": "/",
  "display": "standalone",
  "display_override": ["standalone", "minimal-ui"],
  "background_color": "#0B1220",
  "theme_color": "#0B1220",
  "orientation": "portrait-primary",
  "scope": "/",
  "lang": "fr",
  "dir": "ltr",
  "categories": ["music", "social", "education", "lifestyle"],
  "icons": [
    {
      "src": "/pwa-icons/icon-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-icons/icon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/pwa-icons/icon-maskable-192x192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "maskable"
    },
    {
      "src": "/pwa-icons/icon-maskable-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ],
  "screenshots": [
    {
      "src": "/pwa-icons/screenshot-wide.png",
      "sizes": "1280x720",
      "type": "image/png",
      "form_factor": "wide",
      "label": "Accueil Arborisis"
    },
    {
      "src": "/pwa-icons/screenshot-narrow.png",
      "sizes": "750x1334",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "Accueil mobile Arborisis"
    }
  ],
  "shortcuts": [
    {
      "name": "Explorer",
      "short_name": "Explorer",
      "description": "Découvrir les sons de la nature",
      "url": "/sounds",
      "icons": [{ "src": "/pwa-icons/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Carte",
      "short_name": "Carte",
      "description": "Explorer la carte sonore",
      "url": "/map",
      "icons": [{ "src": "/pwa-icons/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Radio",
      "short_name": "Radio",
      "description": "Écouter la radio nature",
      "url": "/radio",
      "icons": [{ "src": "/pwa-icons/icon-192x192.png", "sizes": "192x192" }]
    },
    {
      "name": "Profil",
      "short_name": "Profil",
      "description": "Mon profil et mes sons",
      "url": "/dashboard",
      "icons": [{ "src": "/pwa-icons/icon-192x192.png", "sizes": "192x192" }]
    }
  ],
  "share_target": {
    "action": "/sounds/create",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "description",
      "files": [
        {
          "name": "audio",
          "accept": ["audio/*", "application/octet-stream"]
        }
      ]
    }
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  }
}
