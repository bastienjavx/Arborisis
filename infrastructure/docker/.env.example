HTTP_PORT=80
DISCORD_BOT_PORT=3001
ARBORISIS_IMAGE_TAG=local
ARBORISIS_APP_ENV_FILE=../../<redacted>/.env
ARBORISIS_DISCORD_ENV_FILE=../../<redacted>/discord-bot/.env
CLOUDFLARED_IMAGE=cloudflare/cloudflared:latest
CLOUDFLARE_TUNNEL_TOKEN=

APP_ENV=production
APP_DEBUG=false

POSTGRES_DB=<redacted>
POSTGRES_USER=<redacted>
